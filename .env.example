# ──────────────────────────────────────────────────────────────
# Environment variables for the portfolio
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored, so your secrets stay out of the repo.
# ──────────────────────────────────────────────────────────────

# Formspree endpoint for the contact form (optional).
# Create a form at https://formspree.io to get your endpoint, e.g.
#   https://formspree.io/f/abcdwxyz
# If this is left unset, the contact form falls back to opening the
# visitor's email client with the message pre-filled.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
